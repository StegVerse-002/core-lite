{
  "schema": "stegverse.heartbeat_policy.v1",
  "version": "0.1.3-gllm",
  "entity": "StegVerse-002",
  "repo": "StegVerse-002/core-lite",
  "authority": {
    "candidate_evidence_only": true,
    "canonical_authority": false,
    "broad_authority": false,
    "may_bind_repo_state": false
  },
  "heartbeat_modes": {
    "fast": {
      "interval_minutes": 1,
      "max_consecutive_beats": 10,
      "allowed_when": [
        "PARTIAL_PROOF",
        "PROOF_INVALID",
        "missing transition_bundle_ingest_receipt",
        "ingest diagnostics present and unresolved"
      ],
      "downgrade_to": "normal"
    },
    "normal": {
      "interval_minutes": 5,
      "allowed_when": [
        "MISSING_PROOF",
        "PARTIAL_PROOF",
        "activation pending",
        "post-repair verification pending"
      ],
      "downgrade_to": "resting"
    },
    "resting": {
      "interval_minutes": 60,
      "allowed_when": [
        "PROOF_COMPLETE",
        "no drift detected"
      ],
      "escalate_to": "normal"
    },
    "event_triggered": {
      "interval_minutes": 0,
      "allowed_when": [
        "task.md changed",
        "workflow changed",
        "schema changed",
        "ingestion script changed",
        "package script changed",
        "incoming payload changed",
        "proof artifact changed",
        "receipt changed",
        "authority policy changed"
      ]
    }
  },
  "health_rules": {
    "deny_broad_authority": true,
    "candidate_admission_is_not_installation": true,
    "fail_closed_on_invalid_proof": true,
    "record_receipts_on_non_admit_decisions": true,
    "do_not_create_unbounded_recursive_runs": true
  },
  "activation_target": {
    "required_status": "PROOF_COMPLETE",
    "required_artifacts": [
      "dist/bundles/proposed_transition_bundle.json",
      "dist/bundles/proposed_transition_bundle.zip",
      "dist/bundles/proposed_transition_bundle.sha256",
      "receipts/current/proposed_transition_bundle_receipt.jsonl",
      "receipts/current/transition_bundle_ingest_receipt.jsonl"
    ],
    "next_boundary": "destination_admissibility_receipt"
  }
}
