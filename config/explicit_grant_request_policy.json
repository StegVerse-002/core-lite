  "expected_promotion_result": "PROMOTION_READY_FOR_EXPLICIT_GRANT_REQUEST",
  "request_result": "EXPLICIT_GRANT_REQUEST_RECORDED",
  "grant_boundary": {
    "this_request_grants_authority": false,
    "this_request_installs": false,
    "requires_future_review": true,
    "requires_separate_grant_decision": true
  }
}
